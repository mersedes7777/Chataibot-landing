<script>
  // scroll reveal
  const io=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}})},{threshold:.12});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

  // живой чат — печатает, отвечает, по кругу
  const script=[
    {who:'them',text:'Здравствуйте! 🌸'},
    {who:'them',text:'Хочу заказать букет на завтра к 12:00'},
    {who:'me',text:'Здравствуйте! Конечно 🙂 Подскажите повод — подберу идеальный букет'},
    {who:'them',text:'День рождения мамы'},
    {who:'me',text:'Прекрасно! Советую «Нежность» — пионы и розы 💐 На какой адрес доставить?'},
    {who:'them',text:'Улица Ленина 15'},
    {who:'me',text:'Готово! Оформил на завтра 12:00. Добавить открытку с текстом?'},
    {who:'them',text:'Да, «Любимой маме» ❤️'},
    {who:'me',text:'Записал! Заказ оформлен, скоро подтвердим. Спасибо! 🌷'},
  ];
  const chat=document.getElementById('chat');
  function delay(ms){return new Promise(r=>setTimeout(r,ms))}
  function scrollDown(){chat.scrollTop=chat.scrollHeight}
  function addTyping(who){
    const t=document.createElement('div');
    t.className='typing'+(who==='me'?' me':'');
    t.innerHTML='<span></span><span></span><span></span>';
    chat.appendChild(t);scrollDown();return t;
  }
  function addBub(who,text){
    const b=document.createElement('div');
    b.className='bub '+who+' appear';b.textContent=text;
    chat.appendChild(b);scrollDown();
  }
  async function runChat(){
    while(true){
      chat.innerHTML='';await delay(500);
      for(const m of script){
        const t=addTyping(m.who);
        // пауза зависит от длины сообщения — как будто реально печатают
        await delay(Math.min(700+m.text.length*22, m.who==='me'?1600:1200));
        t.remove();
        addBub(m.who,m.text);
        await delay(m.who==='me'?700:500);
      }
      await delay(3000);
    }
  }
  // чат идёт сразу при загрузке (видно движение при открытии)
  runChat();
</script>
